# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=beyos

# Auth — secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret-string

# OnePay (onepay.lk) payment gateway — get these from your OnePay merchant dashboard
ONEPAY_APP_ID=your_onepay_app_id
ONEPAY_APP_TOKEN=your_onepay_app_token
ONEPAY_HASH_SALT=your_onepay_hash_salt
