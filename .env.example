# MySQL connection
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=beyos

# Auth — secret used to sign session JWTs. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret-string
APP_BASE_URL=https://your-production-domain.example

# Transactional email (password resets)
RESEND_API_KEY=your_resend_api_key
MAIL_FROM=Beyos Clothing <no-reply@your-domain.example>

# OnePay (onepay.lk) payment gateway — get these from your OnePay merchant dashboard
ONEPAY_APP_ID=your_onepay_app_id
ONEPAY_APP_TOKEN=your_onepay_app_token
ONEPAY_HASH_SALT=your_onepay_hash_salt

# Koombiyo Delivery (server-side only)
KOOMBIYO_CODE=KOOBIYO
KOOMBIYO_NAME=Koobiyo
KOOMBIYO_ACCOUNT=your_koombiyo_account_name
KOOMBIYO_API_BASE_URL=https://application.koombiyodelivery.lk/api/
KOOMBIYO_API_KEY=your_koombiyo_api_key
KOOMBIYO_PHONE=your_koombiyo_contact_phone
KOOMBIYO_EMAIL=your_koombiyo_contact_email
KOOMBIYO_DEFAULT_DISTRICT_ID=1
KOOMBIYO_DEFAULT_CITY_ID=1

# Dialog eSMS (server-side only). Generate the URL Message Key in the eSMS portal.
ESMS_URL_MESSAGE_KEY=your_dialog_esms_url_message_key
ESMS_BASE_URL=https://e-sms.dialog.lk
ESMS_SOURCE_ADDRESS=BEYOS
