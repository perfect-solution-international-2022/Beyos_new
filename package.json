    "jose": "5.9.6",
    "mysql2": "3.11.3",
    "next": "15.5.20",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zustand": "4.5.5"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.14",
    "typescript": "5.5.4"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
